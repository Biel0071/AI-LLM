# ====================================================
# AI PLATFORM - Variaveis de ambiente
# Copie para .env e ajuste. Local -> VPS: so mude aqui.
# ====================================================

# ----- Runtime -----
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ----- Banco de dados (PostgreSQL) -----
DATABASE_URL=postgresql://aiplatform:aiplatform@localhost:5432/aiplatform?schema=public
# Porta exposta no HOST pelo docker-compose (nao afeta DATABASE_URL acima,
# que usa a rede interna do Docker). Mude so se a 5432 do host ja estiver
# ocupada por outro Postgres na mesma maquina (comum em VPS compartilhada).
POSTGRES_HOST_PORT=5432

# ----- Redis -----
REDIS_URL=redis://localhost:6379
# Mesma ideia do POSTGRES_HOST_PORT acima, para a porta do Redis no host.
REDIS_HOST_PORT=6379

# ----- Seguranca -----
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@aiplatform.local
ADMIN_PASSWORD=admin123
# Chave de API padrao criada no bootstrap (para conectar o Lovable em <5min).
# Deixe vazio para gerar automaticamente (sera exibida no log do primeiro boot).
DEFAULT_API_KEY=ap_dev_change_me

# ----- Rate limit -----
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# ----- Cache inteligente -----
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
MODEL_CONFIG_VERSION=1
FREE_PROVIDER_ORDER=ollama,groq,gemini,cloudflare,openrouter,lmstudio

# ----- Observabilidade -----
METRICS_ENABLED=true

# ----- Defaults por capacidade (nome do provider) -----
DEFAULT_TEXT_PROVIDER=ollama
DEFAULT_CHAT_PROVIDER=ollama
DEFAULT_IMAGE_PROVIDER=comfyui
DEFAULT_EMBED_PROVIDER=ollama
DEFAULT_VISION_PROVIDER=ollama
DEFAULT_UPSCALE_PROVIDER=comfyui

# ----- Ollama (local) -----
OLLAMA_BASE_URL=http://localhost:11434
# Roteamento automatico por tarefa (packages/shared/src/model-router.ts):
#   - chat / texto geral / sem task informada -> OLLAMA_DEFAULT_MODEL (rapido por padrao)
#   - translation / seo                        -> OLLAMA_FAST_MODEL (pequeno e rapido)
#   - classification / task=quality            -> OLLAMA_QUALITY_MODEL (mais qualidade)
#   - vision / ocr                             -> OLLAMA_VISION_MODEL (multimodal de verdade)
#   - embed                                    -> OLLAMA_EMBED_MODEL
# So entra em acao quando o chamador NAO informa um "model" explicito.
# Baixe cada um com: ollama pull <modelo>
OLLAMA_DEFAULT_MODEL=qwen2.5:1.5b
OLLAMA_FAST_MODEL=qwen2.5:1.5b
OLLAMA_QUALITY_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=moondream
OLLAMA_EMBED_MODEL=nomic-embed-text

# ----- OpenAI -----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_IMAGE_MODEL=dall-e-3

# ----- Google Gemini -----
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# ----- Anthropic Claude -----
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-opus-4-8

# ----- Quality gate local (sem provider externo) -----
MIN_OUTPUT_QUALITY=90
QUALITY_GATE_STRICT=true

# ----- OpenRouter -----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openrouter/free

# ----- Groq (plano gratuito) -----
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# ----- Cloudflare Workers AI (franquia gratuita diaria) -----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_BASE_URL=
CLOUDFLARE_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct-fp8-fast
CLOUDFLARE_EMBED_MODEL=@cf/baai/bge-m3

# ----- LM Studio (local, OpenAI compativel) -----
LMSTUDIO_BASE_URL=
LMSTUDIO_DEFAULT_MODEL=

# ----- ComfyUI -----
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors
COMFYUI_UPSCALE_MODEL=RealESRGAN_x4plus.pth
COMFYUI_TIMEOUT_MS=300000
# Perfil padrao; projetos podem sobrescrever width/height/steps por request.
COMFYUI_DEFAULT_WIDTH=512
COMFYUI_DEFAULT_HEIGHT=512
COMFYUI_DEFAULT_STEPS=3
# LCM-LoRA opcional (models/loras/) - reduz passos de ~20-25 para poucos.
# Essencial em VPS sem GPU. Deixe vazio para desativar. So use isso se o
# checkpoint NAO tem o LCM-LoRA mesclado - reaplicar via node a cada
# geracao custa ~30s fixos por chamada (ver COMFYUI_LCM_MODE abaixo).
#COMFYUI_LCM_LORA=lcm-lora-sdv1-5.safetensors
# Ativa os defaults de sampler do regime LCM (poucos passos, cfg baixo,
# resolucao menor) sem custo de node LoraLoader - use quando o checkpoint
# configurado acima JA TEM o LCM-LoRA mesclado permanentemente (ver
# scripts/vps-merge-lcm-checkpoint.sh). Ligado automaticamente se
# COMFYUI_LCM_LORA estiver definido; so precisa setar aqui se o LoRA ja
# estiver mesclado no arquivo do checkpoint.
#COMFYUI_LCM_MODE=true

# ----- Automatic1111 (Stable Diffusion WebUI) -----
A1111_BASE_URL=
A1111_DEFAULT_MODEL=

# ----- Stable Diffusion API (modelslab / stablediffusionapi.com) -----
SD_API_BASE_URL=https://modelslab.com/api
SD_API_KEY=
SD_API_TEXT2IMG_PATH=/v3/text2img

# ----- Replicate -----
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell
REPLICATE_TEXT_MODEL=meta/meta-llama-3-70b-instruct

# ----- Workers / Filas -----
WORKER_CONCURRENCY=4
# Chamadas /v1/text em modo auto acima deste limite viram jobs 202.
SYNC_TEXT_CONCURRENCY=1
IMAGE_WORKER_CONCURRENCY=1
GLOBAL_WORKER_CONCURRENCY=4
ADAPTIVE_CONCURRENCY=true
RESOURCE_CHECK_INTERVAL_MS=15000
# So aumenta concorrencia depois de 3 leituras saudaveis; reduz imediatamente.
RESOURCE_RECOVERY_SAMPLES=3
PROVIDER_FAILURE_THRESHOLD=2
PROVIDER_COOLDOWN_MS=30000
# Segredo global de fallback para assinatura HMAC dos callbacks.
WEBHOOK_SIGNING_SECRET=
# Mantenha false em producao; true somente para callbacks HTTP internos confiaveis.
WEBHOOK_ALLOW_HTTP=false
WEBHOOK_TIMEOUT_MS=10000
BATCH_MAX_JOBS=10000
# Quantos registros do lote sao inseridos simultaneamente no Postgres/Redis.
BATCH_ENQUEUE_CONCURRENCY=25
# Limite por job /image-gallery. Em VPS CPU-only use 1; em GPU pode ser 5.
GALLERY_MAX_IMAGES_PER_JOB=5
QUEUE_PREFIX=aiplatform
JOB_WAIT_TIMEOUT_MS=180000

# ----- OCR -----
# vision = usa modelo multimodal | tesseract = usa binario tesseract instalado
OCR_ENGINE=vision
